SECRET_KEY=unsafe-dev-secret-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (compose overrides POSTGRES_HOST to "db")
POSTGRES_DB=cube_bi
POSTGRES_USER=cube_bi
POSTGRES_PASSWORD=cube_bi_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Data provider: "mock" (reads local DB) or "http" (calls real customer API)
DATA_PROVIDER=mock
HTTP_PROVIDER_BASE_URL=
HTTP_PROVIDER_API_KEY=

# JWT refresh cookie
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

# CORS - frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
